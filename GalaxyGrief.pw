<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Магазин доната | GalaxyGrief</title>
    <meta name="description" content="Официальный магазин доната сервера GalaxyGrief. Привилегии за Telegram Stars: Основа-Консоль 500⭐, Овнер 250⭐, Админ, Мл. Админ, Пегас, Дадмин, Дмодер.">
    <meta name="keywords" content="GalaxyGrief, майнкрафт сервер, донат, Telegram Stars, привилегии, консоль, овнер, админ, дадмин, дмодер">
    <meta name="robots" content="index, follow">
    <meta property="og:title" content="GalaxyGrief — Магазин доната">
    <meta property="og:description" content="Основа-Консоль 500⭐, Овнер 250⭐ и другие привилегии. Низкие цены!">
    <meta property="og:type" content="website">
    <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><text y=%22.9em%22 font-size=%2290%22>⭐</text></svg>">
    <link href="https://fonts.googleapis.com/css2?family=Press+Start+2P&display=swap" rel="stylesheet">
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            background-color: #0d0d0d;
            background-image: radial-gradient(circle at 20% 30%, rgba(100, 80, 20, 0.3) 0%, transparent 30%),
                radial-gradient(circle at 80% 70%, rgba(100, 80, 20, 0.2) 0%, transparent 40%),
                repeating-linear-gradient(45deg, #1a1a1a 0px, #1a1a1a 2px, #222 2px, #222 4px);
            font-family: 'Press Start 2P', monospace;
            color: #fff;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            align-items: center;
            padding: 20px;
            position: relative;
            overflow-x: hidden;
        }
        .pixel-particle {
            position: fixed; width: 8px; height: 8px; background: #f5e56c;
            opacity: 0; z-index: -1; animation: floatUp 6s infinite linear;
        }
        @keyframes floatUp {
            0% { transform: translateY(100vh) rotate(0deg); opacity: 0; }
            10% { opacity: 0.8; } 90% { opacity: 0.2; }
            100% { transform: translateY(-10vh) rotate(360deg); opacity: 0; }
        }
        .container { max-width: 1200px; width: 100%; position: relative; }
        .header {
            text-align: center; margin-bottom: 40px; padding: 25px 20px;
            background: rgba(0, 0, 0, 0.7); border: 4px solid #b89b40; border-radius: 16px;
            box-shadow: 0 0 30px rgba(0,0,0,0.9), inset 0 0 20px rgba(0,0,0,0.7);
            position: relative; backdrop-filter: blur(10px);
        }
        .header::before {
            content: ""; position: absolute; top: -6px; left: -6px; right: -6px; bottom: -6px;
            background: linear-gradient(135deg, #f5e56c, #8b6f1c, #f5e56c);
            border-radius: 20px; z-index: -1; opacity: 0.5; filter: blur(5px);
        }
        .header h1 {
            font-size: 2.5rem; color: #f5e56c; text-shadow: 4px 4px 0 #000, 0 0 15px rgba(245,229,108,0.5);
            letter-spacing: 4px; margin-bottom: 12px; animation: glow 2s ease-in-out infinite alternate;
        }
        @keyframes glow {
            from { text-shadow: 4px 4px 0 #000, 0 0 10px rgba(245,229,108,0.3); }
            to { text-shadow: 4px 4px 0 #000, 0 0 25px rgba(245,229,108,0.7); }
        }
        .header p { font-size: 0.7rem; color: #ddd; text-shadow: 1px 1px 0 #000; margin: 6px 0; line-height: 1.6; }
        .star-icon { color: #f5e56c; font-size: 1.3rem; vertical-align: middle; animation: spin 3s infinite linear; display: inline-block; }
        @keyframes spin { 0% { transform: rotate(0deg); } 100% { transform: rotate(360deg); } }
        .donate-grid {
            display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 30px; margin-bottom: 50px;
        }
        .donate-card {
            background: #222; border: 4px solid #5a4a2e; border-radius: 20px;
            padding: 25px 20px 20px; text-align: center; position: relative;
            transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            box-shadow: 0 8px 20px rgba(0,0,0,0.6), inset 0 1px 3px rgba(255,255,255,0.1);
            background-image: linear-gradient(145deg, #2a2a2a 0%, #1a1a1a 100%);
            display: flex; flex-direction: column; align-items: center; justify-content: space-between;
            cursor: pointer; transform-origin: center;
        }
        .donate-card:hover {
            transform: translateY(-10px) scale(1.02); border-color: #f5e56c;
            box-shadow: 0 20px 35px rgba(0,0,0,0.9), 0 0 25px rgba(245,229,108,0.6);
            background-image: linear-gradient(145deg, #3a3a3a 0%, #2a2a2a 100%);
        }
        .donate-card::before {
            content: ""; position: absolute; top: 0; left: 0; right: 0; bottom: 0;
            background: repeating-linear-gradient(0deg, rgba(255,255,200,0.03) 0px, rgba(255,255,200,0.03) 4px, transparent 4px, transparent 8px);
            pointer-events: none; border-radius: 16px;
        }
        .donate-icon { font-size: 5rem; margin-bottom: 15px; filter: drop-shadow(0 8px 10px rgba(0,0,0,0.7)); transition: transform 0.3s; z-index: 1; position: relative; }
        .donate-card:hover .donate-icon { transform: scale(1.1) rotate(-5deg); }
        .card-title { font-size: 1.3rem; color: #fff; margin-bottom: 12px; text-shadow: 2px 2px 0 #000; letter-spacing: 1.5px; z-index: 1; position: relative; }
        .price-section { margin: 15px 0; z-index: 1; position: relative; }
        .old-price { font-size: 0.9rem; color: #aaa; text-decoration: line-through; margin-bottom: 5px; display: block; opacity: 0.8; }
        .new-price { font-size: 2.2rem; color: #f5e56c; font-weight: bold; text-shadow: 2px 2px 0 #000; display: block; margin: 5px 0; letter-spacing: 2px; }
        .discount-badge {
            display: inline-block; background: #c0392b; color: #fff; font-size: 0.7rem;
            padding: 6px 14px; border-radius: 20px; margin-top: 8px;
            box-shadow: 0 3px 8px rgba(0,0,0,0.6); letter-spacing: 0.5px; border: 2px solid #e67e22;
        }
        .buy-button {
            display: inline-block; margin-top: 18px; padding: 12px 28px;
            background: #5a8f3c; color: #fff; text-decoration: none; font-size: 0.8rem;
            border: 3px solid #2d4a1a; border-radius: 8px; transition: all 0.2s ease;
            box-shadow: 0 5px 0 #2d4a1a; text-shadow: 1px 1px 0 #000; letter-spacing: 1.5px;
            position: relative; z-index: 2; cursor: pointer;
            background-image: linear-gradient(to bottom, #6ea847, #4a7a2e); outline: none;
        }
        .buy-button:hover { background: #7db853; border-color: #3d5c22; box-shadow: 0 5px 0 #3d5c22; transform: translateY(-2px); filter: brightness(1.1); }
        .buy-button:active { transform: translateY(3px); box-shadow: 0 2px 0 #2d4a1a; }
        .price-table-section {
            margin: 40px auto; max-width: 800px; background: rgba(0,0,0,0.6);
            border: 3px solid #b89b40; border-radius: 16px; padding: 20px; backdrop-filter: blur(5px);
        }
        .price-table-section h2 { text-align: center; color: #f5e56c; margin-bottom: 20px; font-size: 1.3rem; text-shadow: 2px 2px 0 #000; }
        .price-table { width: 100%; border-collapse: collapse; font-size: 0.65rem; text-align: left; }
        .price-table th { background: #b89b40; color: #000; padding: 10px 8px; text-shadow: none; border: 2px solid #8b6f1c; }
        .price-table td { padding: 10px 8px; border: 2px solid #5a4a2e; color: #ddd; }
        .price-table tr:nth-child(even) { background: rgba(255,255,200,0.05); }
        .price-table .old-price-cell { text-decoration: line-through; color: #aaa; font-size: 0.55rem; }
        .price-table .new-price-cell { color: #f5e56c; font-weight: bold; }
        .modal-overlay {
            position: fixed; top: 0; left: 0; width: 100%; height: 100%;
            background: rgba(0,0,0,0.8); backdrop-filter: blur(5px);
            display: flex; align-items: center; justify-content: center; z-index: 1000;
            visibility: hidden; opacity: 0; transition: visibility 0.3s, opacity 0.3s;
        }
        .modal-overlay.active { visibility: visible; opacity: 1; }
        .modal {
            background: #2b2b2b; border: 4px solid #b89b40; border-radius: 20px;
            padding: 30px; max-width: 500px; width: 90%; text-align: center;
            box-shadow: 0 0 50px rgba(0,0,0,0.9), 0 0 30px rgba(245,229,108,0.4);
            position: relative; animation: modalIn 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            background-image: linear-gradient(160deg, #333 0%, #1f1f1f 100%); color: #fff;
        }
        @keyframes modalIn {
            from { transform: scale(0.7) translateY(-50px); opacity: 0; }
            to { transform: scale(1) translateY(0); opacity: 1; }
        }
        .modal-close {
            position: absolute; top: 15px; right: 20px; font-size: 2rem; color: #f5e56c;
            cursor: pointer; text-shadow: 2px 2px 0 #000; transition: 0.2s; line-height: 1;
        }
        .modal-close:hover { color: #fff; transform: scale(1.2); }
        .modal-icon { font-size: 5rem; margin-bottom: 15px; }
        .modal h2 { font-size: 1.8rem; color: #f5e56c; margin-bottom: 15px; text-shadow: 2px 2px 0 #000; }
        .modal-description {
            font-size: 0.7rem; line-height: 1.7; color: #ddd; margin: 20px 0;
            text-align: left; background: rgba(0,0,0,0.4); padding: 15px;
            border-radius: 10px; border-left: 4px solid #f5e56c;
        }
        .modal-description ul { list-style: none; padding-left: 0; }
        .modal-description li { padding: 5px 0; display: flex; align-items: center; gap: 8px; }
        .modal-description li::before { content: "⛏️"; font-size: 0.8rem; }
        .modal-price { font-size: 1.8rem; color: #f5e56c; margin: 15px 0; }
        .modal .buy-button { font-size: 0.9rem; padding: 14px 30px; }
        .footer {
            text-align: center; margin-top: auto; padding: 25px;
            background: rgba(0,0,0,0.7); border-top: 3px solid #b89b40;
            border-radius: 16px; width: 100%; backdrop-filter: blur(5px);
        }
        .footer p { font-size: 0.65rem; color: #aaa; margin: 6px 0; }
        .telegram-link {
            display: inline-block; margin-top: 12px; background: #0088cc; color: #fff;
            padding: 10px 24px; border-radius: 30px; text-decoration: none; font-size: 0.75rem;
            transition: all 0.3s; box-shadow: 0 4px 10px rgba(0,136,204,0.4); letter-spacing: 0.5px;
        }
        .telegram-link:hover { background: #00a2f0; box-shadow: 0 6px 15px rgba(0,136,204,0.6); transform: translateY(-2px); }
        .support-info { margin-top: 12px; font-size: 0.6rem; color: #f5e56c; opacity: 0.9; letter-spacing: 0.5px; }
        @media (max-width: 600px) {
            .header h1 { font-size: 1.8rem; }
            .donate-icon { font-size: 4rem; }
            .new-price { font-size: 1.8rem; }
            .price-table { font-size: 0.5rem; }
        }
    </style>
</head>
<body>
    <div class="container">
        <div class="header">
            <h1>⚔️ GALAXYGRIEF ⚔️</h1>
            <p>Все цены в <span class="star-icon">⭐</span> Telegram Stars</p>
            <p>Нажми на карточку, чтобы узнать подробности</p>
            <p style="font-size:0.6rem; color:#f5e56c;">Покупай через чат <strong>@unsenu</strong></p>
        </div>

        <div class="donate-grid" id="donateGrid"></div>

        <div class="price-table-section">
            <h2>📊 ПОЛНАЯ ТАБЛИЦА ЦЕН</h2>
            <table class="price-table">
                <thead>
                    <tr>
                        <th>Ранг</th>
                        <th>Старая цена</th>
                        <th>Новая цена</th>
                        <th>Скидка</th>
                    </tr>
                </thead>
                <tbody id="priceTableBody"></tbody>
            </table>
        </div>

        <div class="footer">
            <p>© GalaxyGrief Donate. Все права защищены.</p>
            <p>Связь с администрацией:</p>
            <a href="https://t.me/unsenu" target="_blank" class="telegram-link">💬 Написать @unsenu</a>
            <div class="support-info">
                Создано при поддержке <a href="https://t.me/unsenu" style="color:#f5e56c; text-decoration:underline;">@unsenu</a> и Windows11
            </div>
        </div>
    </div>

    <div class="modal-overlay" id="modalOverlay">
        <div class="modal">
            <span class="modal-close" id="modalClose">&times;</span>
            <div class="modal-icon" id="modalIcon"></div>
            <h2 id="modalTitle"></h2>
            <div class="modal-description" id="modalDesc"></div>
            <div class="modal-price" id="modalPrice"></div>
            <a href="#" class="buy-button" id="modalBuyBtn" target="_blank">💎 Купить в Telegram</a>
        </div>
    </div>

    <script>
        // Новая иерархия: Овнер (топ), Основа-Консоль, Админ, Мл. Админ, Пегас, Дадмин, Дмодер
        const donateItems = [
            {
                id: 'owner',
                icon: '👑',
                title: 'Овнер',
                oldPrice: '500 ⭐',
                newPrice: '250 ⭐',
                discount: '-50%',
                description: `
                    <ul>
                        <li>Полный доступ ко всем функциям сервера</li>
                        <li>Управление игроками и мирами</li>
                        <li>Высший приоритет в чате и ивентах</li>
                        <li>Уникальный префикс и цвет ника</li>
                        <li>Создание кастомных команд</li>
                    </ul>
                `,
                telegramText: 'Привет!%20Хочу%20купить%20Овнера'
            },
            {
                id: 'console',
                icon: '🖥️',
                title: 'Основа-Консоль',
                oldPrice: '750 ⭐',
                newPrice: '500 ⭐',
                discount: '-33%',
                description: `
                    <ul>
                        <li>Доступ к консоли сервера</li>
                        <li>Управление плагинами</li>
                        <li>Приоритетная очередь при входе</li>
                        <li>Настройка миров и правил</li>
                    </ul>
                `,
                telegramText: 'Привет!%20Хочу%20купить%20Основу-Консоль'
            },
            {
                id: 'admin',
                icon: '⚡',
                title: 'Админ',
                oldPrice: '400 ⭐',
                newPrice: '200 ⭐',
                discount: '-50%',
                description: `
                    <ul>
                        <li>Полный административный доступ</li>
                        <li>Управление игроками (бан/кик)</li>
                        <li>Выдача предметов и наград</li>
                        <li>Проведение ивентов</li>
                    </ul>
                `,
                telegramText: 'Привет!%20Хочу%20купить%20Админа'
            },
            {
                id: 'junior_admin',
                icon: '🛠️',
                title: 'Мл. Админ',
                oldPrice: '300 ⭐',
                newPrice: '150 ⭐',
                discount: '-50%',
                description: `
                    <ul>
                        <li>Помощь старшим админам</li>
                        <li>Мониторинг чата</li>
                        <li>Выдача предупреждений</li>
                        <li>Участие в тестировании обновлений</li>
                    </ul>
                `,
                telegramText: 'Привет!%20Хочу%20купить%20Мл.%20Админа'
            },
            {
                id: 'pegasus',
                icon: '🦄',
                title: 'Пегас',
                oldPrice: '250 ⭐',
                newPrice: '120 ⭐',
                discount: '-52%',
                description: `
                    <ul>
                        <li>Летающий маунт Пегас</li>
                        <li>Увеличенная скорость полёта</li>
                        <li>Неуязвимость при падении</li>
                        <li>Доступ в небесные биомы</li>
                    </ul>
                `,
                telegramText: 'Привет!%20Хочу%20купить%20Пегаса'
            },
            {
                id: 'head_admin',
                icon: '🔥',
                title: 'Дадмин',
                oldPrice: '200 ⭐',
                newPrice: '100 ⭐',
                discount: '-50%',
                description: `
                    <ul>
                        <li>Помощь в чате и контроль</li>
                        <li>Предупреждения и мут</li>
                        <li>Участие в жизни сервера</li>
                        <li>Помощь игрокам</li>
                    </ul>
                `,
                telegramText: 'Привет!%20Хочу%20купить%20Дадмина'
            },
            {
                id: 'dmoder',
                icon: '🛡️',
                title: 'Дмодер',
                oldPrice: '160 ⭐',
                newPrice: '80 ⭐',
                discount: '-50%',
                description: `
                    <ul>
                        <li>Модерация чата</li>
                        <li>Выдача предупреждений</li>
                        <li>Помощь новичкам</li>
                    </ul>
                `,
                telegramText: 'Привет!%20Хочу%20купить%20Дмодера'
            }
        ];

        // Генерация карточек
        const grid = document.getElementById('donateGrid');
        donateItems.forEach(item => {
            const card = document.createElement('div');
            card.className = 'donate-card';
            card.dataset.id = item.id;
            card.innerHTML = `
                <div class="donate-icon">${item.icon}</div>
                <div class="card-title">${item.title}</div>
                <div class="price-section">
                    <span class="old-price">${item.oldPrice}</span>
                    <span class="new-price">${item.newPrice}</span>
                    <div class="discount-badge">${item.discount}</div>
                </div>
                <a href="https://t.me/unsenu?text=${item.telegramText}" target="_blank" class="buy-button" onclick="event.stopPropagation();">💎 Купить</a>
            `;
            card.addEventListener('click', (e) => {
                if (e.target.closest('.buy-button')) return;
                openModal(item);
            });
            grid.appendChild(card);
        });

        // Заполнение таблицы
        const tableBody = document.getElementById('priceTableBody');
        donateItems.forEach(item => {
            const row = document.createElement('tr');
            row.innerHTML = `
                <td>${item.icon} ${item.title}</td>
                <td class="old-price-cell">${item.oldPrice}</td>
                <td class="new-price-cell">${item.newPrice}</td>
                <td>${item.discount}</td>
            `;
            tableBody.appendChild(row);
        });

        // Модалка
        const modalOverlay = document.getElementById('modalOverlay');
        const modalClose = document.getElementById('modalClose');
        const modalIcon = document.getElementById('modalIcon');
        const modalTitle = document.getElementById('modalTitle');
        const modalDesc = document.getElementById('modalDesc');
        const modalPrice = document.getElementById('modalPrice');
        const modalBuyBtn = document.getElementById('modalBuyBtn');

        function openModal(item) {
            modalIcon.textContent = item.icon;
            modalTitle.textContent = item.title;
            modalDesc.innerHTML = item.description;
            modalPrice.innerHTML = `${item.newPrice} <span style="font-size:0.8rem; color:#aaa;">вместо ${item.oldPrice}</span> <span style="background:#c0392b; padding:2px 8px; border-radius:10px; font-size:0.7rem;">${item.discount}</span>`;
            modalBuyBtn.href = `https://t.me/unsenu?text=${item.telegramText}`;
            modalOverlay.classList.add('active');
        }

        function closeModal() { modalOverlay.classList.remove('active'); }
        modalClose.addEventListener('click', closeModal);
        modalOverlay.addEventListener('click', (e) => { if (e.target === modalOverlay) closeModal(); });
        document.addEventListener('keydown', (e) => { if (e.key === 'Escape' && modalOverlay.classList.contains('active')) closeModal(); });

        // Частицы
        function createParticles() {
            const colors = ['#f5e56c', '#e67e22', '#f1c40f', '#b89b40'];
            for (let i = 0; i < 15; i++) {
                const particle = document.createElement('div');
                particle.className = 'pixel-particle';
                particle.style.left = Math.random() * 100 + '%';
                particle.style.backgroundColor = colors[Math.floor(Math.random() * colors.length)];
                particle.style.width = (4 + Math.random() * 8) + 'px';
                particle.style.height = particle.style.width;
                particle.style.animationDuration = (5 + Math.random() * 10) + 's';
                particle.style.animationDelay = Math.random() * 5 + 's';
                document.body.appendChild(particle);
            }
        }
        createParticles();
    </script>
</body>
</html>
